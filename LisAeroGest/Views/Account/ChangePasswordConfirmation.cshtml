@{
    ViewData["Title"] = "Password Alterada";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm border-success">
                <div class="card-header bg-success text-white text-center py-3">
                    <h4 class="mb-0">
                        <i class="bi bi-check-circle-fill me-2"></i>Password Alterada
                    </h4>
                </div>
                <div class="card-body p-4 text-center">
                    <i class="bi bi-shield-check text-success" style="font-size: 4rem;"></i>
                    <h5 class="mt-3">Password alterada com sucesso!</h5>
                    <p class="text-muted">
                        A sua password foi alterada. Use a nova password no próximo login.
                    </p>
                    <a asp-action="Index" asp-controller="Home" class="btn btn-primary mt-2">
                        <i class="bi bi-house me-2"></i>Ir para o Início
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>