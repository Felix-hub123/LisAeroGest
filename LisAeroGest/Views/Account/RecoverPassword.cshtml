@model LisAeroGest.Models.RecoverPasswordViewModel
@{
    ViewData["Title"] = "Recuperar Password";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white text-center py-3">
                    <h4 class="mb-0">
                        <i class="bi bi-key-fill me-2"></i>Recuperar Password
                    </h4>
                    <small>LisAeroGest — Aeroporto de Lisboa</small>
                </div>
                <div class="card-body p-4">
                    <p class="text-muted small mb-4">
                        Introduza o seu email e enviaremos um link para redefinir a sua password.
                    </p>
                    <form asp-action="RecoverPassword" method="post">
                        @Html.AntiForgeryToken()
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                        <div class="mb-4">
                            <label asp-for="Email" class="form-label fw-semibold"></label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-envelope"></i></span>
                                <input asp-for="Email" class="form-control" placeholder="email@exemplo.com" />
                            </div>
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>

                        <div class="d-grid">
                            <button type="submit" class="btn btn-primary btn-lg">
                                <i class="bi bi-send me-2"></i>Enviar Link
                            </button>
                        </div>
                    </form>
                </div>
                <div class="card-footer text-center py-3">
                    <a asp-action="Login" class="text-muted small">
                        <i class="bi bi-arrow-left me-1"></i>Voltar ao Login
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
