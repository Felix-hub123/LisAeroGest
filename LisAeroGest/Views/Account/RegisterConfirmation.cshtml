@{
    ViewData["Title"] = "Registo Concluído";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm border-success">
                <div class="card-header bg-success text-white text-center py-3">
                    <h4 class="mb-0">
                        <i class="bi bi-check-circle-fill me-2"></i>Registo Concluído
                    </h4>
                </div>
                <div class="card-body p-4 text-center">
                    <i class="bi bi-envelope-check-fill text-success" style="font-size: 4rem;"></i>
                    <h5 class="mt-3">Verifique o seu email!</h5>
                    <p class="text-muted">
                        @ViewBag.Message
                    </p>
                    <p class="text-muted small">
                        Após confirmar o email, poderá fazer login na plataforma.
                    </p>
                    <a asp-action="Login" class="btn btn-primary mt-2">
                        <i class="bi bi-box-arrow-in-right me-2"></i>Ir para o Login
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>