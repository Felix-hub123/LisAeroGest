@{
    ViewData["Title"] = "Acesso Negado";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm border-danger">
                <div class="card-header bg-danger text-white text-center py-3">
                    <h4 class="mb-0">
                        <i class="bi bi-shield-x-fill me-2"></i>Acesso Negado
                    </h4>
                </div>
                <div class="card-body p-4 text-center">
                    <i class="bi bi-exclamation-triangle-fill text-danger" style="font-size: 4rem;"></i>
                    <h5 class="mt-3">Não tem permissão para aceder a esta página</h5>
                    <p class="text-muted">
                        A sua conta não tem privilégios suficientes para aceder a este recurso.
                        Se acredita que isto é um erro, contacte o administrador.
                    </p>
                    <a asp-action="Index" asp-controller="Home" class="btn btn-primary mt-2">
                        <i class="bi bi-house me-2"></i>Ir para o Início
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>