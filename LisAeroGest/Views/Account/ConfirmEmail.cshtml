@{
    ViewData["Title"] = "Confirmação de Email";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white text-center py-3">
                    <h4 class="mb-0">
                        <i class="bi bi-envelope-check me-2"></i>Confirmação de Email
                    </h4>
                </div>
                <div class="card-body p-4 text-center">

                    @if (ViewBag.Message != null && ViewBag.Message.ToString().Contains("sucesso"))
                    {
                        <i class="bi bi-check-circle-fill text-success" style="font-size: 4rem;"></i>
                        <h5 class="mt-3 text-success">Email Confirmado!</h5>
                    }
                    else
                    {
                        <i class="bi bi-x-circle-fill text-danger" style="font-size: 4rem;"></i>
                        <h5 class="mt-3 text-danger">Erro na Confirmação</h5>
                    }

                    <p class="text-muted mt-2">@ViewBag.Message</p>

                    <a asp-action="Login" class="btn btn-primary mt-3">
                        <i class="bi bi-box-arrow-in-right me-2"></i>Ir para o Login
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>