@model LisAeroGest.Models.AirportViewModel

@{
    ViewData["Title"] = "Editar Aeroporto";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-7">

            <div class="d-flex align-items-center mb-4">
                <a asp-action="Index" class="btn btn-outline-secondary btn-sm me-3">
                    <i class="bi bi-arrow-left"></i>
                </a>
                <h2 class="fw-bold mb-0">
                    <i class="bi bi-pencil-fill text-warning me-2"></i>Editar Aeroporto
                </h2>
            </div>

            <div class="card shadow-sm">
                <div class="card-body p-4">
                    <form asp-action="Edit" method="post" enctype="multipart/form-data">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                        <input asp-for="Id" type="hidden" />
                        <input asp-for="ImageId" type="hidden" />

                        <div class="row">
                            <div class="col-md-8 mb-3">
                                <label asp-for="Name" class="form-label fw-semibold"></label>
                                <input asp-for="Name" class="form-control" />
                                <span asp-validation-for="Name" class="text-danger small"></span>
                            </div>
                            <div class="col-md-4 mb-3">
                                <label asp-for="IATACode" class="form-label fw-semibold"></label>
                                <input asp-for="IATACode" class="form-control text-uppercase"
                                       maxlength="3" />
                                <span asp-validation-for="IATACode" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="City" class="form-label fw-semibold"></label>
                                <input asp-for="City" class="form-control" />
                                <span asp-validation-for="City" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="Country" class="form-label fw-semibold"></label>
                                <input asp-for="Country" class="form-control" />
                                <span asp-validation-for="Country" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="DefaultFee" class="form-label fw-semibold"></label>
                            <div class="input-group">
                                <span class="input-group-text">€</span>
                                <input asp-for="DefaultFee" class="form-control" />
                            </div>
                            <span asp-validation-for="DefaultFee" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="ImageFile" class="form-label fw-semibold"></label>
                            <input asp-for="ImageFile" class="form-control" type="file"
                                   accept="image/*" onchange="previewImage(this)" />
                            <div class="mt-2">
                                <img id="imagePreview" src="@Model.ImageFullPath"
                                     class="rounded" style="height:80px; object-fit:cover;" />
                            </div>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-warning">
                                <i class="bi bi-check-lg me-2"></i>Guardar Alterações
                            </button>
                            <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        function previewImage(input) {
            if (input.files && input.files[0]) {
                const reader = new FileReader();
                reader.onload = e => document.getElementById('imagePreview').src = e.target.result;
                reader.readAsDataURL(input.files[0]);
            }
        }
    </script>
}