@model LisAeroGest.Data.Entities.Airport

@{
    ViewData["Title"] = "Eliminar Aeroporto";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">

            <div class="d-flex align-items-center mb-4">
                <a asp-action="Index" class="btn btn-outline-secondary btn-sm me-3">
                    <i class="bi bi-arrow-left"></i>
                </a>
                <h2 class="fw-bold mb-0 text-danger">
                    <i class="bi bi-trash-fill me-2"></i>Eliminar Aeroporto
                </h2>
            </div>

            <div class="card shadow-sm border-danger">
                <div class="card-body p-4">
                    <div class="alert alert-danger">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i>
                        Tem a certeza que pretende eliminar este aeroporto?
                        Esta operação não pode ser revertida.
                    </div>

                    <div class="text-center mb-4">
                        <img src="@Model.ImageFullPath" alt="@Model.Name"
                             class="rounded shadow-sm"
                             style="height:100px; object-fit:cover;" />
                    </div>

                    <table class="table table-borderless">
                        <tr>
                            <th class="text-muted" style="width:35%">Nome</th>
                            <td class="fw-semibold">@Model.Name</td>
                        </tr>
                        <tr>
                            <th class="text-muted">Código IATA</th>
                            <td>
                                <span class="badge bg-primary">@Model.IATACode</span>
                            </td>
                        </tr>
                        <tr>
                            <th class="text-muted">Cidade</th>
                            <td>@Model.City</td>
                        </tr>
                        <tr>
                            <th class="text-muted">País</th>
                            <td>@Model.Country</td>
                        </tr>
                    </table>

                    <form asp-action="Delete" method="post">
                        <input type="hidden" asp-for="Id" />
                        <div class="d-flex gap-2 mt-3">
                            <button type="submit" class="btn btn-danger">
                                <i class="bi bi-trash me-2"></i>Confirmar Eliminação
                            </button>
                            <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>