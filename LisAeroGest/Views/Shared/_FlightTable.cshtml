@model IEnumerable<LisAeroGest.Data.Entities.Flight>
@using LisAeroGest.Helpers
@{
    // O parâmetro "Type" diz à tabela se deve mostrar Destino (partidas) ou Origem (chegadas)
    string type = ViewData["Type"]?.ToString() ?? "Departures";
    bool isDeparture = type == "Departures";
}

@if (!Model.Any())
{
    <div class="text-center text-muted py-5">
        <i class="bi bi-inbox fs-1 d-block mb-2"></i>
        Sem voos registados para hoje.
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead style="background:#0d3d6b; color:white;">
                <tr>
                    <th class="ps-3">Voo</th>
                    <th>Companhia</th>
                    <th>@(isDeparture ? "Destino" : "Origem")</th>
                    <th>@(isDeparture ? "Partida" : "Chegada")</th>
                    <th>Gate</th>
                    <th>Estado</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var flight in Model)
                {
                    var airport = isDeparture ? flight.DestinationAirport : flight.OriginAirport;
                    var time = isDeparture ? flight.DepartureTime : flight.ArrivalTime;

                    <tr class="@FlightStatusHelper.GetRowClass(flight.Status)">
                        <td class="ps-3 fw-bold">@flight.FlightNumber</td>
                        <td>@flight.Airline?.Name</td>
                        <td>
                            <i class="bi bi-geo-alt-fill text-primary me-1"></i>
                            @airport?.City
                            <span class="text-muted small">(@airport?.IATACode)</span>
                        </td>
                        <td>
                            <span class="fw-semibold">@time.ToString("HH:mm")</span>
                            @if (flight.Status == "Delayed" && flight.DelayedDepartureTime.HasValue)
                            {
                                <br />
                                <small class="text-danger">
                                    <i class="bi bi-clock me-1"></i>
                                    @flight.DelayedDepartureTime.Value.ToString("HH:mm")
                                </small>
                            }
                        </td>
                        <td>
                            @if (flight.Gate != null)
                            {
                                <span class="badge bg-dark">@flight.Gate.GateNumber</span>
                            }
                            else
                            {
                                <span class="text-muted">—</span>
                            }
                        </td>
                        <td>
                            <span class="badge @FlightStatusHelper.GetBadgeClass(flight.Status)">
                                @FlightStatusHelper.GetStatusText(flight.Status)
                            </span>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
